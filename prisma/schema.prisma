generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model StoreSettings {
  id        String   @id @default(cuid())
  storeName String   @default("Mi Punto de Venta")
  logoUrl   String?
  taxId     String?
  legalName String?
  address     String?
  phone       String?
  shippingZip String?
  aiProvider  String?
  aiApiKey    String?
  acceptsTransfer       Boolean  @default(false)
  transferBank          String?
  transferAccountHolder String?
  transferCLABE         String?
  transferAccountNumber String?
  transferInstructions  String?
  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt
  sellerId  String?  @unique
  seller    User?    @relation("UserStoreSettings", fields: [sellerId], references: [id])
}

model MarketplaceSettings {
  id                 String   @id @default(cuid())
  title              String   @default("Moda Zapotlanejo")
  heroImage          String?
  heroImages         String[]
  logoUrl            String?
  adminEmail         String?
  sellerLabel        String   @default("Vendedor")
  featuredSellerIds  String[]
  featuredProductIds String[]
  plans              Json?
  privacyUrl         String?
  termsUrl           String?
  photographyPrices  Json?
  brandColors        Json?
  showPricesPublicly Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}

model BrandConfig {
  id                 String   @id @default(cuid())
  domain             String   @unique
  name               String
  tagline            String?
  description        String?
  logoUrl            String?
  heroImage          String?
  heroImages         String[]
  primaryColor       String   @default("blue")
  isSingleVendor     Boolean  @default(false)
  sellerId           String?
  featuredSellerIds  String[]
  featuredProductIds String[]
  featuredCategories String[]
  isActive           Boolean  @default(true)
  showPricesPublicly Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model SellerReview {
  id          String    @id @default(cuid())
  sellerId    String
  buyerId     String
  orderId     String    @unique
  rating      Int
  title       String?
  body        String
  sellerReply String?
  repliedAt   DateTime?
  isVisible   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  buyer       User      @relation("BuyerReviews", fields: [buyerId], references: [id])
  order       Order     @relation(fields: [orderId], references: [id])
  seller      User      @relation("SellerReviews", fields: [sellerId], references: [id])
}

model PosPeripheral {
  id        String   @id @default(cuid())
  sellerId  String
  type      String
  name      String
  config    Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  seller    User     @relation(fields: [sellerId], references: [id])
}

model StoreLocation {
  id                   String                @id @default(cuid())
  name                 String
  address              String?
  isWebStore           Boolean               @default(false)
  ticketHeader         String?
  ticketFooter         String?
  showDateAndTimeToPos Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  sellerId             String?
  sessions             CashRegisterSession[]
  inventory            InventoryLevel[]
  movements            InventoryMovement[]
  sales                Sale[]
  seller               User?                 @relation("SellerLocations", fields: [sellerId], references: [id])
  users                User[]
}

model User {
  id                  String                 @id @default(cuid())
  email               String
  passwordHash        String?
  name                String
  role                Role                   @default(CASHIER)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  isWholesale         Boolean                @default(false)
  businessName        String?
  sellerSlug          String?                @unique
  taxId               String?
  commission          Float?                 @default(5)
  fixedFee            Float?                 @default(0)
  stripeAccountId     String?
  stripeConnectStatus String?
  isActive            Boolean                @default(true)
  adminNotes          String?
  phone               String?
  whatsapp            String?
  minOrderAmount      Float?
  logoUrl             String?
  posEnabled          Boolean                @default(true)
  canOpenDrawer       Boolean?
  maxProducts         Int?
  posRequested        Boolean                @default(false)
  planName            String                 @default("Básico")
  maxLocations        Int                    @default(1)
  maxCashiers         Int                    @default(1)
  managedBySellerId   String?
  allowedLocationIds  String[]
  canRefund           Boolean                @default(true)
  canDiscount         Boolean                @default(true)
  canViewReports      Boolean                @default(false)
  canViewCommissions  Boolean                @default(false)
  canViewZCuts        Boolean                @default(false)
  canCreateProducts   Boolean                @default(false)
  locationId          String?
  resetToken          String?                @unique
  resetTokenExpiry    DateTime?
  registeredDomain    String?
  ownedBrands         Brand[]
  sessions            CashRegisterSession[]
  clients             Client[]
  denominations       CurrencyDenomination[] @relation("SellerDenominations")
  receivedMessages    Message[]              @relation("ReceivedMessages")
  sentMessages        Message[]              @relation("SentMessages")
  buyerOrders         Order[]                @relation("BuyerOrders")
  sellerOrders        Order[]                @relation("SellerOrders")
  paymentMethods      PaymentMethod[]
  photographyRequests PhotographyRequest[]
  posPeripherals      PosPeripheral[]
  priceTiers          PriceTier[]
  ownedProducts       Product[]
  buyerSales          Sale[]                 @relation("BuyerSales")
  soldBySales         Sale[]                 @relation("SoldBySales")
  sales               Sale[]
  buyerReviews        SellerReview[]         @relation("BuyerReviews")
  sellerReviews       SellerReview[]         @relation("SellerReviews")
  sellerSettlements   Settlement[]           @relation("SellerSettlements")
  shippingAddresses   ShippingAddress[]
  ownedLocations      StoreLocation[]        @relation("SellerLocations")
  storeSettings       StoreSettings?         @relation("UserStoreSettings")
  suppliers           Supplier[]
  tags                Tag[]
  location            StoreLocation?         @relation(fields: [locationId], references: [id])
  managedBySeller     User?                  @relation("SellerCashiers", fields: [managedBySellerId], references: [id])
  cashiers            User[]                 @relation("SellerCashiers")
  coupons             DiscountCoupon[]       @relation("SellerCoupons")
  couponUsages        CouponUsage[]          @relation("BuyerCouponUsages")
  wishlistItems       Wishlist[]
  floorSalespeople    Salesperson[]          @relation("SellerFloorSalespeople")

  @@unique([email, registeredDomain])
}

model Category {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  image         String?
  products      Product[]
  subcategories Subcategory[]
}

model Subcategory {
  id         String    @id @default(cuid())
  name       String
  slug       String
  categoryId String
  products   Product[]
  category   Category  @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, slug])
  @@unique([categoryId, name])
}

model Brand {
  id       String    @id @default(cuid())
  name     String
  sellerId String?
  seller   User?     @relation(fields: [sellerId], references: [id])
  products Product[]

  @@unique([sellerId, name])
}

model Product {
  id                   String       @id @default(cuid())
  name                 String
  slug                 String?      @unique
  description          String?
  price                Float
  wholesalePrice       Float?
  cost                 Float?
  sellByPackage        Boolean      @default(false)
  packageSize          Int?
  wholesaleComposition Json?
  brandId              String?
  supplierId           String?
  sellerId             String?
  categoryId           String?
  subcategoryId        String?
  isOnline             Boolean      @default(true)
  isPOS                Boolean      @default(true)
  isActive             Boolean      @default(true)
  images               String[]
  sku                  String?      @unique
  variantOptions       Json?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  promoEndDate         DateTime?
  promoStartDate       DateTime?
  promotionalPrice     Float?
  brand                Brand?       @relation(fields: [brandId], references: [id])
  category             Category?    @relation(fields: [categoryId], references: [id])
  seller               User?        @relation(fields: [sellerId], references: [id])
  subcategory          Subcategory? @relation(fields: [subcategoryId], references: [id])
  supplier             Supplier?    @relation(fields: [supplierId], references: [id])
  variants             Variant[]
  wishlists            Wishlist[]
  tags                 Tag[]        @relation("ProductToTag")
}

model Variant {
  id                 String              @id @default(cuid())
  productId          String
  color              String?
  size               String?
  attributes         Json?
  stock              Int                 @default(0)
  sku                String?             @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inventoryLevels    InventoryLevel[]
  inventoryMovements InventoryMovement[]
  orderItems         OrderItem[]
  saleItems          SaleItem[]
  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  wishlistItems      Wishlist[]

  @@index([productId])
}

model Supplier {
  id          String    @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  notes       String?
  isActive    Boolean   @default(true)
  sellerId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
  seller      User?     @relation(fields: [sellerId], references: [id])

  @@unique([sellerId, name])
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  sellerId  String?
  createdAt DateTime  @default(now())
  seller    User?     @relation(fields: [sellerId], references: [id])
  products  Product[] @relation("ProductToTag")

  @@unique([sellerId, name])
}

model InventoryLevel {
  id         String        @id @default(cuid())
  variantId  String
  locationId String
  stock      Int           @default(0)
  updatedAt  DateTime      @updatedAt
  location   StoreLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variant    Variant       @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, locationId])
}

model InventoryMovement {
  id         String         @id @default(cuid())
  variantId  String
  type       String
  quantity   Int
  reason     String?
  locationId String?
  createdAt  DateTime       @default(now())
  location   StoreLocation? @relation(fields: [locationId], references: [id])
  variant    Variant        @relation(fields: [variantId], references: [id])
}

model Client {
  id                   String                @id @default(cuid())
  name                 String
  email                String?
  phone                String?
  storeCredit          Float                 @default(0)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  sellerId             String?
  seller               User?                 @relation(fields: [sellerId], references: [id])
  sales                Sale[]
  storeAccountPayments StoreAccountPayment[]
}

model PriceTier {
  id                     String   @id @default(cuid())
  name                   String
  discountPercentage     Float?
  costPlusPercentage     Float?
  costPlusFixed          Float?
  defaultPriceMinusFixed Float?
  order                  Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  minQuantity            Int?     @default(0)
  autoApplyMarketplace   Boolean  @default(false)
  autoApplyPOS           Boolean  @default(false)
  manualPOS              Boolean  @default(true)
  sellerId               String?
  orders                 Order[]
  seller                 User?    @relation(fields: [sellerId], references: [id])
  sales                  Sale[]
}

model PaymentMethod {
  id                   String                @id @default(cuid())
  name                 String
  type                 String
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  sellerId             String?
  layawayPayments      LayawayPayment[]
  seller               User?                 @relation(fields: [sellerId], references: [id])
  sales                Sale[]
  storeAccountPayments StoreAccountPayment[]

  @@unique([sellerId, name])
}

model CashRegisterSession {
  id                   String                @id @default(cuid())
  openedAt             DateTime              @default(now())
  closedAt             DateTime?
  openingBalance       Float                 @default(0)
  closingBalance       Float?
  status               String                @default("OPEN")
  locationId           String?
  openedById           String?
  movements            CashMovement[]
  location             StoreLocation?        @relation(fields: [locationId], references: [id])
  openedBy             User?                 @relation(fields: [openedById], references: [id])
  layawayPayments      LayawayPayment[]
  sales                Sale[]
  storeAccountPayments StoreAccountPayment[]
}

model CashMovement {
  id        String              @id @default(cuid())
  sessionId String
  type      String
  amount    Float
  reason    String
  createdAt DateTime            @default(now())
  session   CashRegisterSession @relation(fields: [sessionId], references: [id])
}

model Sale {
  id                    String               @id @default(cuid())
  receiptNumber         Int                  @default(autoincrement())
  total                 Float
  subtotal              Float                @default(0)
  discount              Float                @default(0)
  clientId              String?
  priceTierId           String?
  paymentMethodId       String?
  cashSessionId         String?
  locationId            String?
  sellerId              String?
  buyerId               String?
  soldByUserId          String?
  soldBySalespersonId   String?
  status                String               @default("COMPLETED")
  amountPaid            Float                @default(0)
  balance               Float                @default(0)
  dueDate               DateTime?
  notes                 String?
  paymentSplit          String?
  createdAt             DateTime             @default(now())
  layawayPayments       LayawayPayment[]
  buyer                 User?                @relation("BuyerSales", fields: [buyerId], references: [id])
  cashSession           CashRegisterSession? @relation(fields: [cashSessionId], references: [id])
  client                Client?              @relation(fields: [clientId], references: [id])
  location              StoreLocation?       @relation(fields: [locationId], references: [id])
  paymentMethod         PaymentMethod?       @relation(fields: [paymentMethodId], references: [id])
  priceTier             PriceTier?           @relation(fields: [priceTierId], references: [id])
  seller                User?                @relation(fields: [sellerId], references: [id])
  soldBy                User?                @relation("SoldBySales", fields: [soldByUserId], references: [id])
  salesperson           Salesperson?         @relation(fields: [soldBySalespersonId], references: [id])
  items                 SaleItem[]
}

model Salesperson {
  id              String   @id @default(cuid())
  sellerId        String
  name            String
  phone           String?
  email           String?
  startDate       DateTime @default(now())
  commissionType  String   @default("PERCENT")
  commissionValue Float    @default(0)
  locationIds     String[]
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  seller          User     @relation("SellerFloorSalespeople", fields: [sellerId], references: [id])
  sales           Sale[]
}

model LayawayPayment {
  id              String               @id @default(cuid())
  saleId          String
  amount          Float
  paymentMethodId String?
  cashSessionId   String?
  createdAt       DateTime             @default(now())
  cashSession     CashRegisterSession? @relation(fields: [cashSessionId], references: [id])
  paymentMethod   PaymentMethod?       @relation(fields: [paymentMethodId], references: [id])
  sale            Sale                 @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  variantId String
  quantity  Int
  price     Float
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant   Variant @relation(fields: [variantId], references: [id])
}

model StoreAccountPayment {
  id              String               @id @default(cuid())
  clientId        String
  amount          Float
  type            String               @default("PAYMENT")
  notes           String?
  paymentMethodId String?
  cashSessionId   String?
  createdAt       DateTime             @default(now())
  cashSession     CashRegisterSession? @relation(fields: [cashSessionId], references: [id])
  client          Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod?       @relation(fields: [paymentMethodId], references: [id])
}

model PhotographyRequest {
  id            String   @id @default(cuid())
  userId        String
  itemCount     Int
  estimatedDate DateTime
  notes         String?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model SellerApplication {
  id               String   @id @default(cuid())
  storeName        String
  contactName      String
  email            String   @unique
  phone            String
  category         String
  storeAddress     String?
  shippingZip      String?
  planName         String?
  registeredDomain String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  status           String   @default("PENDING")
}

model Order {
  id                  String           @id @default(cuid())
  orderNumber         Int              @default(autoincrement())
  buyerId             String
  sellerId            String
  status              String           @default("PENDING")
  total               Float
  discount            Float            @default(0)
  notes               String?
  sellerNotes         String?
  paymentMethod       String?
  priceTierId         String?
  shippingAddressId   String?
  shippingCost        Float            @default(0)
  skydropxRateId      String?
  skydropxQuotationId String?
  shippingCarrier     String?
  shippingServiceName String?
  sourceDomain        String?
  commissionRate          Float            @default(0)
  commissionAmount        Float            @default(0)
  sellerEarnings          Float            @default(0)
  isSettled               Boolean          @default(false)
  stripePaymentIntentId   String?
  paymentReleasedAt       DateTime?
  refundedAt              DateTime?
  settlementId        String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  buyer               User             @relation("BuyerOrders", fields: [buyerId], references: [id])
  priceTier           PriceTier?       @relation(fields: [priceTierId], references: [id])
  seller              User             @relation("SellerOrders", fields: [sellerId], references: [id])
  settlement          Settlement?      @relation(fields: [settlementId], references: [id])
  shippingAddress     ShippingAddress? @relation(fields: [shippingAddressId], references: [id])
  items               OrderItem[]
  review              SellerReview?
  shipment            Shipment?
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  variantId   String
  quantity    Int
  price       Float
  productName String
  color       String?
  size        String?
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant     Variant @relation(fields: [variantId], references: [id])
}

model ShippingAddress {
  id          String   @id @default(cuid())
  userId      String
  label       String   @default("Principal")
  name        String
  phone       String
  street      String
  colonia     String
  city        String
  state       String
  zip         String
  country     String   @default("MX")
  referencias String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  orders      Order[]
  user        User     @relation(fields: [userId], references: [id])
}

model Shipment {
  id             String   @id @default(cuid())
  orderId        String   @unique
  carrier        String
  serviceName    String
  trackingNumber String?
  labelUrl       String?
  skydropxId     String?
  shippingCost   Float
  status         String   @default("PENDING")
  estimatedDays  Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  order          Order    @relation(fields: [orderId], references: [id])
}

model Settlement {
  id              String   @id @default(cuid())
  sellerId        String
  amount          Float
  commissionTotal Float
  ordersCount     Int
  status          String   @default("PENDING")
  paymentMethod   String?
  reference       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          Order[]
  seller          User     @relation("SellerSettlements", fields: [sellerId], references: [id])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])

  @@index([senderId, receiverId])
  @@index([receiverId, isRead])
}

model Wishlist {
  id                String   @id @default(cuid())
  userId            String
  productId         String
  createdAt         DateTime @default(now())
  variantId         String?
  notifyOnRestock   Boolean  @default(true)
  notifyOnPriceDown Boolean  @default(true)
  lastKnownPrice    Float?
  lastKnownStock    Int?
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id])
  variant           Variant? @relation(fields: [variantId], references: [id])

  @@unique([userId, productId])
}

model CurrencyDenomination {
  id        String   @id @default(cuid())
  label     String
  value     Float
  sortOrder Int      @default(0)
  sellerId  String
  createdAt DateTime @default(now())
  seller    User     @relation("SellerDenominations", fields: [sellerId], references: [id])

  @@unique([sellerId, value])
}

model DiscountCoupon {
  id               String         @id @default(cuid())
  code             String
  sellerId         String
  discountType     String         // "PERCENTAGE" | "FIXED"
  discountValue    Float
  minPurchase      Float          @default(0)
  maxUses          Int?
  maxUsesPerBuyer  Int?           // null = sin límite por comprador
  usedCount        Int            @default(0)
  startsAt         DateTime?
  expiresAt        DateTime?
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  seller           User           @relation("SellerCoupons", fields: [sellerId], references: [id])
  usages           CouponUsage[]

  @@unique([code, sellerId])
  @@index([sellerId])
}

model CouponUsage {
  id        String         @id @default(cuid())
  couponId  String
  buyerId   String
  usedAt    DateTime       @default(now())
  coupon    DiscountCoupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  buyer     User           @relation("BuyerCouponUsages", fields: [buyerId], references: [id])

  @@index([couponId, buyerId])
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
  BUYER
  SELLER
}
